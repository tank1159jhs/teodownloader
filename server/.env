# =================================
# 환경변수 설정
# =================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# Node 환경
NODE_ENV=production

# 포트
PORT=3000

# =================================
# yt-dlp Proxy 설정 (선택사항)
# =================================
# TikTok/Instagram IP 차단 우회용
# 형식: http://proxy.example.com:8080
#      socks5://proxy.example.com:1080
YTDLP_PROXY=

# =================================
# 광고 코드 (선택사항)
# =================================
MONETAG_ZONE_ID=발급받은_숫자_ID
MONETAG_SMARTLINK_URL=https://발급받은_스마트링크_주소
ADSTERRA_SOCIAL_BAR_ID=발급받은_소셜바_ID

# =================================
# 모니터링 (선택사항)
# =================================
# Discord/Slack webhook URL (에러 알림용)
WEBHOOK_URL=

# 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info