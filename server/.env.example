# =================================
# 환경변수 설정
# =================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# Node 환경
NODE_ENV=production

# 포트
PORT=3000

# =================================
# Cloudflare R2 설정 (우선 권장)
# =================================
# Cloudflare R2 API tokens에서 획득
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket 정보
S3_BUCKET_NAME=your-bucket-name
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# AWS region (R2는 일반적으로 auto 사용)
AWS_REGION=auto

# =================================
# yt-dlp Proxy 설정 (선택사항)
# =================================
# TikTok/Instagram IP 차단 우회용
# 형식: http://proxy.example.com:8080
#      socks5://proxy.example.com:1080
YTDLP_PROXY=

# yt-dlp Cookies 설정 (선택사항)
# YouTube/TikTok 성인 인증 및 차단 우회용
# 형식: /home/opc/cookies.txt
YTDLP_COOKIES=

# =================================
# 광고 코드 (선택사항)
# =================================
PROPELLERADS_CODE=
ADSTERRA_CODE=

# =================================
# 모니터링 (선택사항)
# =================================
# Discord/Slack webhook URL (에러 알림용)
WEBHOOK_URL=

# 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info
